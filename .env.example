# Optional: override API base (defaults to /api/v1 via Vite proxy in dev)
# Do NOT set in local dev unless you need cross-origin API calls.
# VITE_API_URL=http://127.0.0.1:3000

# Production (Railway frontend service — required at build time when API is on another host)
# VITE_API_URL=https://api.cursorhelp.com
# Runtime alias supported by server.mjs (optional):
# CURSORHELP_API_BASE_URL=https://api.cursorhelp.com

# Override Vite dev proxy target (default http://localhost:3000)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000
