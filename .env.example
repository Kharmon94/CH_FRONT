# Optional: override API host (defaults to /api/v1 via Vite proxy in dev)
# Do NOT set in local dev unless you need cross-origin API calls.
# VITE_API_URL=http://127.0.0.1:3000

# --- Cloud control plane (www.cursorhelp.com production build) ---
# Host only; api.ts appends /api/v1 automatically.
# VITE_CLOUD_API_URL=https://api.cursorhelp.com

# --- Desktop / launcher (bin/cursorhelp or Tauri shell) ---
# Local Rails engine (database, export, discover). Default http://127.0.0.1:3847
# VITE_LOCAL_API_URL=http://127.0.0.1:3847
# VITE_LOCAL_ENGINE_PORT=3847
# VITE_DESKTOP_UI_PORT=3848
# Set true when building UI embedded in Tauri (enables desktop auth bridge).
# VITE_DESKTOP_APP=true
#
# Runtime proxy for server.mjs (launcher serves dist/ on :3848, proxies /api → engine).
# CURSORHELP_API_UPSTREAM=http://127.0.0.1:3847
#
# OAuth: Google sign-in from desktop uses next=/app/oauth/desktop/callback, then
# cursorhelp://auth?token=… — register the web callback in Google Console only;
# the custom scheme is handled by the Tauri shell (tauri.conf.json deep-link).

# Download page asset URLs (host signed/public installer files before launch)
# VITE_DOWNLOAD_URL_WINDOWS=https://releases.cursorhelp.com/desktop/CursorHelp-setup.exe
# VITE_DOWNLOAD_URL_MAC=https://releases.cursorhelp.com/desktop/CursorHelp.dmg
# VITE_DOWNLOAD_URL_LINUX=https://releases.cursorhelp.com/desktop/CursorHelp.AppImage
# VITE_DOWNLOAD_URL_LAUNCHER=https://releases.cursorhelp.com/desktop/cursorhelp-launcher.zip

# Production (Railway frontend — set at build time)
# Host only; api.ts appends /api/v1 automatically
# VITE_API_URL=https://api.cursorhelp.com

# Override Vite dev proxy target (default http://localhost:3000)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# Canonical site URL for SEO meta tags and JSON-LD (build-time)
# VITE_SITE_URL=https://www.cursorhelp.com

# Runtime API upstream for server.mjs (/api proxy + sitemap; default http://localhost:3000)
# CURSORHELP_API_UPSTREAM=https://api.cursorhelp.com
